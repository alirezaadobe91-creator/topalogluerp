{
  "entities": {
    "Order": {
      "title": "Order",
      "description": "A jewelry order record",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the order" },
        "customerName": { "type": "string", "description": "Name of the customer" },
        "orderNumber": { "type": "string", "description": "The order number from the marketplace" },
        "marketplace": { "type": "string", "description": "Marketplace where the order was placed (e.g., Trendyol, Hepsiburada)" },
        "status": { "type": "string", "description": "Current status of the order" },
        "erpStatus": { "type": "string", "description": "Status in the ERP system" },
        "items": { "type": "array", "description": "List of items in the order" },
        "totalAmount": { "type": "number", "description": "Total order amount" },
        "createdAt": { "type": "number", "description": "Creation timestamp" },
        "updatedAt": { "type": "number", "description": "Last update timestamp" },
        "userId": { "type": "string", "description": "ID of the user who owns this order" }
      },
      "required": ["id", "customerName", "orderNumber", "marketplace", "status", "userId"]
    }
  },
  "firestore": {
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Global collection of orders"
    }
  }
}
